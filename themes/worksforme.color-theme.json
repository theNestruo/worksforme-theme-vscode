{
	"$schema": "vscode://schemas/color-theme",
	"name": "Works for Me",
	"colors": {
		/*
		 * Partially clones "Dark (Visual Studio)" workbench style
		 * (https://github.com/microsoft/vscode/blob/main/extensions/theme-defaults/themes/dark_vs.json)
		 */

		"checkbox.border": "#6B6B6B",
		"editor.inactiveSelectionBackground": "#3A3D41",
		"editorIndentGuide.background1": "#404040",
		"editorIndentGuide.activeBackground1": "#707070",
		"editor.selectionHighlightBackground": "#ADD6FF26",
		"list.dropBackground": "#383B3D",
		"sideBarTitle.foreground": "#BBBBBB",
		"input.placeholderForeground": "#A6A6A6",
		"menu.background": "#252526",
		"menu.foreground": "#CCCCCC",
		"menu.separatorBackground": "#454545",
		"menu.border": "#454545",
		"menu.selectionBackground": "#0078d4",
		"statusBarItem.remoteForeground": "#FFF",
		"ports.iconRunningProcessForeground": "#369432",
		"tab.selectedBackground": "#222222",
		"tab.selectedForeground": "#ffffffa0",
		"list.activeSelectionIconForeground": "#FFF",
		"terminal.inactiveSelectionBackground": "#3A3D41",
		"widget.border": "#303031",
		"actionBar.toggledBackground": "#383a49",

		/*
		 * Customizes editor
		 */

		"editor.background": "#121212", // (slightly darker editor, default is "#1e1e1e")
		"editor.foreground": "#d4d4d4", // (default is "#d4d4d4")
		"editor.lineHighlightBackground": "#1e1e1e",
		"editor.lineHighlightBorder": "#0000",

		// Dimmed indent guides, line numbers, rulers and whitespace
		"editorGutter.foldingControlForeground": "#d4d4d480",
		"editorLineNumber.activeForeground": "#d4d4d460", // (default is "#c6c6c6")
		"editorLineNumber.foreground": "#d4d4d420", // (default is "#858585")
		"editorRuler.foreground": "#d4d4d420", // (default is "#5a5a5a")
		"editorWhitespace.foreground": "#d4d4d440", // (default is "#e3e4e229")

		// More visible ocurrences highlight
		"editor.wordHighlightBackground": "#00a7cc60",

		// More visible inlay hints
		"editorInlayHint.background": "#07314e", // (50% statusBar.background)
		"editorInlayHint.foreground": "#d4d4d4", // (50% #bebebe + 50% #ffffff)

		// More visible errors
		"editorError.background": "#f14c4c60", // (60 opacity of default editorError.foreground: #f14c4c)
		"editorWarning.background": "#cca70060", // (60 opacity of default editorWarning.foreground: #cca700)

		/*
		 * Customizes workbench
		 */

		"titleBar.activeBackground": "#1e1e1e",
		"titleBar.inactiveBackground": "#1e1e1e",
		"activityBar.background": "#1e1e1e",
		"sideBar.background": "#1e1e1e",
		"sideBarSectionHeader.background": "#0000",
		"editorGroupHeader.tabsBackground": "#1e1e1e",
		"editorGroupHeader.noTabsBackground": "#1e1e1e",
		"editorWidget.background": "#252526", // (same as menu.background)
		"listFilterWidget.background": "#252526",
		"tab.inactiveBackground": "#1e1e1e",
		"tab.activeBackground": "#121212",
		"tab.unfocusedActiveBorderTop": "#454545",
		"tab.border": "#0000",
		"tab.lastPinnedBorder": "#454545",
		"terminal.border": "#0000",
		"panel.background": "#1e1e1e",
		"quickInput.background": "#252526",

		// Few borders to improve readability:
		"editorGroup.border": "#454545",
		"panel.border": "#454545",
		"sideBarSectionHeader.border": "#454545",

		// Active/accent colors:
		"activityBarBadge.background": "#0e639c", // (same as badge.background)
		"badge.background": "#0e639c",
		"editorWidget.resizeBorder": "#0e639c", // (same as badge.background)
		"panelTitle.activeBorder": "#0098ff",
		"tab.activeBorderTop": "#0098ff",
		"terminal.tab.activeBorder": "#0098ff",

		// Restores the "classic" status bar colors:
		"statusBar.background": "#0e639c", // (darker and less intense than default "#007acc")
		"statusBar.debuggingBackground": "#cc6633",
		"statusBar.focusBorder": "#0000",
		"statusBar.foreground": "#ffffff",
		"statusBar.noFolderBackground": "#68217a",
		"statusBarItem.remoteBackground": "#16825d",

		/*
		 * Customizes terminal
		 */

		// Clones "Ottosson"
		// (https://github.com/microsoft/terminal/blob/main/src/cascadia/TerminalSettingsModel/defaults.json#L107)
		"terminal.background": "#000000",
		"terminal.foreground": "#bebebe",
		"terminal.selectionBackground": "#92a4fd",
		"terminal.ansiBlack": "#000000",
		"terminal.ansiRed": "#be2c21",
		"terminal.ansiGreen": "#3fae3a",
		"terminal.ansiYellow": "#be9a4a",
		"terminal.ansiBlue": "#204dbe",
		"terminal.ansiMagenta": "#bb54be",
		"terminal.ansiCyan": "#00a7b2",
		"terminal.ansiWhite": "#bebebe",
		"terminal.ansiBrightBlack": "#808080",
		"terminal.ansiBrightRed": "#ff3e30",
		"terminal.ansiBrightGreen": "#58ea51",
		"terminal.ansiBrightYellow": "#ffc944",
		"terminal.ansiBrightBlue": "#2f6aff",
		"terminal.ansiBrightMagenta": "#fc74ff",
		"terminal.ansiBrightCyan": "#00e1f0",
		"terminal.ansiBrightWhite": "#ffffff"
	},
	"semanticHighlighting": false,
	"tokenColors": [

		/*
		 * Typography ---------------------------------------------------------
		 */
		{
			"scope": [
				"markup.italic",
				"emphasis"
			],
			"settings": {
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"markup.bold",
				"strong"
			],
			"settings": {
				"fontStyle": "bold"
			}
		},
		{
			"scope": "markup.underline",
			"settings": {
				"fontStyle": "underline"
			}
		},
		{
			"scope": "markup.strikethrough",
			"settings": {
				"fontStyle": "strikethrough"
			}
		},

		/*
		 * Keywords -----------------------------------------------------------
		 */
		{
			"name": "Keywords",
			"scope": [
				"keyword",
				"storage.type",
				"storage.modifier",
				// (not not keywords)
				"keyword.operator.alignas",
				"keyword.operator.alignof",
				"keyword.operator.cast",
				"keyword.operator.expression",
				"keyword.operator.instanceof",
				"keyword.operator.new",
				"keyword.operator.sizeof",
				"keyword.operator.ternary",
				"keyword.operator.typeid",
				"keyword.operator.wordlike",
				//
				// Key-value-based languages ----------------------------------
				"source.json constant.language",
				"source.yaml constant.language",
				//
				// Text-based languages ---------------------------------------
				"text.html entity.name.tag",
				"text.html.markdown punctuation.definition.quote",
				"text.html.markdown meta.link.inline",
				"text.xml entity.name.tag",
				//
				// Code -------------------------------------------------------
				// [Assembly]
				"source.z80asm meta.preprocessor.flag.z80asm",
				// [CSS]
				"source.css entity.name.tag",
				"source.css support.constant",
				"source.css support.function",
				// [Java]
				"source.java storage.type.primitive",
				// [Makefile]
				"source.makefile variable.language",
				"source.makefile constant.other.placeholder",
				// [Shell]
				"source.shell support.function.builtin",
				// [Typescript]
				"source.ts support.type.builtin",
				"source.ts support.type.primitive",
			],
			"settings": {
				"foreground": "#569cd6", // ("keyword" from "Dark (Visual Studio)")
				"fontStyle": ""
			}
		},
		{
			"name": "Special keywords: language constants and variables",
			"scope": [
				"constant.language",
				"variable.language",
			],
			"settings": {
				"foreground": "#b5cea8", // ("constant.numeric" from "Dark (Visual Studio)")
				"fontStyle": "italic"
			}
		},

		/*
		 * Literals -----------------------------------------------------------
		 */
		{
			"name": "Literals",
			"scope": [
				"constant",
				"string",
				//
				// Text-based languages ---------------------------------------
				"text.html meta.attribute.id string",
				"text.html meta.attribute.name string",
				"text.html constant.character.entity.named",
				//
				// Code -------------------------------------------------------
				// [Batchfile]
				"source.batchfile variable",
				// [CSS]
				"source.css entity.other.attribute-name.class",
				"source.css entity.other.attribute-name.class punctuation",
				// [Makefile]
				"source.makefile variable",
			],
			"settings": {
				"foreground": "#b5cea8", // ("constant.numeric" from "Dark (Visual Studio)"))
				"fontStyle": ""
			}
		},
		{
			"name": "Dimmed literals, dimmed content within literals",
			"scope": [
				"keyword.other.unit",
				//
				// Key-value-based languages ----------------------------------
				"source.json string constant",
				//
				// Code -------------------------------------------------------
				// [C]
				"source.c string constant.character.escape.c",
				"source.c string constant.other.placeholder.c",
				// [C++]
				"source.cpp string constant.character.escape.cpp",
				// [Javascript]
				"source.js string.template punctuation.definition.template-expression",
				"source.js string.template meta.template.expression",
				"source.js string.regexp keyword.control",
				"source.js string.regexp keyword.operator",
				"source.js string.regexp punctuation.definition.character-class",
				"source.js string.regexp punctuation.definition.group",
				// [Makefile]
				"source.makefile string.interpolated.makefile",
				"source.makefile string.interpolated.makefile variable",
				// [Typescript]
				"source.ts string.template punctuation.definition.template-expression",
				"source.ts string.template meta.template.expression",
				"source.ts string.regexp keyword.control",
				"source.ts string.regexp keyword.operator",
				"source.ts string.regexp punctuation.definition.character-class",
				"source.ts string.regexp punctuation.definition.group",
			],
			"settings": {
				"foreground": "#ce9178", // ("string" from "Dark (Visual Studio)"))
				"fontStyle": ""
			}
		},

		/*
		 * Highlights ---------------------------------------------------------
		 */
		{
			"name": "Highlights (Headings, structure)",
			"scope": [
				// Key-value-based languages ----------------------------------
				"source.json punctuation.definition.array",
				"source.yaml punctuation.definition.block.sequence",
				//
				// Text-based languages ---------------------------------------
				"text.html.markdown heading",
				"text.html.markdown punctuation.definition.heading.markdown",
				//
				// Code -------------------------------------------------------
				// [Assembly]
				"source.z80asm entity.name.function.z80asm",
				// [Batch]
				"source.batchfile keyword.operator.conditional",
				// [Makefile]
				"source.makefile entity.name.function.target.makefile",
				// [Shell]
				"source.shell punctuation.separator.statement.and",
				"source.shell punctuation.separator.statement.or",
			],
			"settings": {
				"foreground": "#f4f4f4",
				"fontStyle": ""
			}
		},

		/*
		 * Dimmed -------------------------------------------------------------
		 */
		{
			"name": "Dimmed and italic (annotations, directives, generics)",
			"scope": [
				// Code -------------------------------------------------------
				// [Assembly]
				"source.z80asm keyword.control",
				// [C++]
				"source.cpp entity.name.scope-resolution",
				"source.cpp meta.template storage.type.template",
				"source.cpp meta.template entity.name.type.template",
				"source.cpp punctuation.section.angle-brackets.begin.template.definition.cpp",
				"source.cpp punctuation.section.angle-brackets.end.template.definition.cpp",
				// [Java]
				"source.java meta.declaration.annotation",
				"source.java meta.declaration.annotation constant.other.key.java",
				"source.java punctuation.bracket.angle.java",
				"source.java storage.type.annotation",
				"source.java storage.type.generic",
				// [Typescript]
				"source.ts entity.name.type.module",
				"source.ts meta.type.parameters",
			],
			"settings": {
				"foreground": "#b4b4b4", // (halfway between editor.foreground and comment)
				"fontStyle": "italic"
			}
		},
		{
			"name": "Dimmed (visual noise)",
			"scope": [
				"punctuation.terminator.statement", // ;
				//
				// Key-value-based languages ----------------------------------
				"source.json punctuation.definition.dictionary",
				//
				// Text-based languages ---------------------------------------
				"text.html string",
				"text.html.markdown entity.name.tag",
				"text.html.markdown fenced_code.block.language",
				"text.html.markdown meta.image.inline",
				"text.xml string",
				//
				// Code -------------------------------------------------------
				// [C]
				"source.c punctuation.separator.pointer-access", // ->
				"source.c punctuation.separator.scope-resolution", // ::
				// [C++]
				"source.cpp punctuation.separator.pointer-access", // ->
				"source.cpp punctuation.separator.scope-resolution", // ::
				"source.cpp storage.modifier.pointer.cpp", // *
				"source.cpp storage.modifier.reference.cpp", // &
				// [Java]
				"source.java punctuation.terminator.java",
				// [Typescript]
				"source.ts keyword.operator.optional.ts", // ?:
				"source.ts keyword.operator.spread.ts", // ...
				"source.ts keyword.operator.type.ts", // & |
				"source.ts punctuation.accessor.optional.ts", // ?.
			],
			"settings": {
				"foreground": "#b4b4b4", // (halfway between editor.foreground and comment)
				"fontStyle": ""
			}
		},

		/*
		 * Fainted ------------------------------------------------------------
		 */
		{
			"name": "Fainted and italic (comments)",
			"scope": [
				"comment",
				//
				// Code -------------------------------------------------------
				// [Batch]
				"source.batchfile keyword.command.rem",
			],
			"settings": {
				"foreground": "#797981",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Fainted, italic and bold (special comments)",
			"scope": [
				// Code -------------------------------------------------------
				// [Java]
				"source.java keyword.other.documentation.javadoc",
				// [Typescript]
				"source.ts storage.type.class.jsdoc",
			],
			"settings": {
				"foreground": "#797981",
				"fontStyle": "italic bold"
			}
		},
		{
			"name": "Fainted (visual noise)",
			"scope": [
				"punctuation.definition.string",
				//
				// Key-value-based languages ----------------------------------
				"source.json punctuation",
				"source.yaml punctuation",
				"source.yaml keyword", // |
				//
				// Text-based languages ---------------------------------------
				"text.html constant.character.entity.named.nbsp",
				"text.html meta.tag",
				"text.html meta.tag.inline.br entity.name.tag",
				"text.html punctuation",
				"text.html.markdown string.other.link.description",
				"text.xml meta.tag",
				"text.xml punctuation",
				//
				// Code -------------------------------------------------------
				// [Batch]
				"source.batchfile constant.character.escape", // ^
				"source.batchfile keyword.operator.at", // @
				// [C]
				"source.c constant.character.escape.line-continuation.c", // \
				// [CSS]
				"source.css punctuation",
				// [Javascript]
				"source.js meta.objectliteral.js punctuation.separator.comma.js", // ,
				"source.js meta.objectliteral.js punctuation.separator.key-value.js", // :
				// [Makefile]
				"source.makefile constant.character.escape.continuation.makefile", // \
			],
			"settings": {
				"foreground": "#797981",
				"fontStyle": ""
			}
		},

		/*
		 * Restores editor.foreground -----------------------------------------
		 */
		{
			"name": "Not keywords",
			"scope": [
				//
				// Not keywords -----------------------------------------------
				//
				"keyword.operator",
				//
				// [CSS]
				"source.css keyword",
				// [Java]
				"source.java storage.modifier.package.java",
				"source.java storage.modifier.import.java",
				"source.java storage.type",
				//
				// Not literals -----------------------------------------------
				//
				// Key-value-based languages
				"source.json support.type.property-name.json",
				"source.yaml entity.name.tag.yaml",
				"source.js meta.object-literal.key.js string", // (JSON within JS)
				//
				// Text-based languages
				"text.html.markdown string.other.link.title",
				"text.html.markdown punctuation.definition.list",
				//
				// Not fainted -----------------------------------------------
				//
				// [CSS]
				"source.css punctuation.definition.keyword",
				"source.css punctuation.definition.entity",
			],
			"settings": {
				"foreground": "#d4d4d4", // (restores editor.foreground)
				"fontStyle": ""
			}
		},

		/*
		 * Diff ---------------------------------------------------------------
		 */
		{
			"scope": "source.diff meta.diff.header",
			"settings": {
				"foreground": "#f4f4f4",
				"fontStyle": ""
			}
		},
		{
			"scope": [
				"source.diff meta.diff.index",
				"source.diff meta.diff.range",
			],
			"settings": {
				"foreground": "#797981",
				"fontStyle": ""
			}
		},
		{
			"scope": [
				"source.diff meta.diff.header.from-file",
				"source.diff meta.diff.header.to-file",
			],
			"settings": {
				"foreground": "#569cd6",
				"fontStyle": ""
			}
		},
		{
			"scope": "source.diff markup.inserted",
			"settings": {
				"foreground": "#b5cea8",
				"fontStyle": ""
			}
		},
		{
			"scope": "source.diff markup.deleted",
			"settings": {
				"foreground": "#ce9178",
				"fontStyle": "strikethrough"
			}
		},
		{
			"scope": "source.diff markup.changed",
			"settings": {
				"foreground": "#569cd6",
				"fontStyle": ""
			}
		},
	]
}
